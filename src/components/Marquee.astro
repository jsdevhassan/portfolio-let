---
// Marquee ticker strip
const items = [
  'Full-Stack Development',
  'System Architecture',
  'API Design',
  'Performance Engineering',
  'UI Engineering',
  'React & Next.js',
  'Node & Python',
  'Database Design',
];
---

<div class="marquee-strip border-y border-white/[0.07] py-[13px] overflow-hidden flex" aria-hidden="true">
  <div class="marquee-inner flex whitespace-nowrap animate-[mqrun_24s_linear_infinite] hover:[animation-play-state:paused]">
    {[...items, ...items].map((item) => (
      <span class="mq-item font-display text-[14px] tracking-[0.18em] text-white/[0.18] px-[38px]">
        {item} <span class="text-white/[0.4]">&middot;</span>
      </span>
    ))}
  </div>
</div>
