---
// Contact section with footer
---

<section id="contact" class="border-t border-white/[0.07] pt-[clamp(80px,12vh,160px)] pb-20 px-[clamp(20px,4vw,64px)]">
  <p class="s-label font-mono text-[11px] tracking-[0.32em] text-white/[0.26] uppercase flex items-center gap-3 mb-14">
    <span class="block w-7 h-px bg-white/[0.18]"></span>
    <span class="text-white/[0.18] mr-1.5">04</span> Get In Touch
  </p>

  <!-- Big heading -->
  <div class="contact-big font-display font-bold text-[clamp(52px,10.5vw,158px)] leading-[0.86] tracking-[-0.01em] text-white/[0.07] mb-[60px] transition-colors duration-[600ms] hover:text-white/[0.12] reveal">
    Let&apos;s Build<br/>
    <span class="text-white/[0.72]">Something</span><br/>
    Together
  </div>

  <!-- Contact row -->
  <div class="contact-row flex items-end justify-between flex-wrap gap-10">
    <!-- Links -->
    <div class="c-links flex flex-col gap-3.5 reveal">
      <a href="https://wa.me/8801782213173" target="_blank" class="c-link font-mono text-[10.5px] tracking-[0.2em] text-white/[0.45] uppercase inline-flex items-center gap-3 transition-colors duration-300 relative pb-[2px] hover:text-white no-underline" data-scramble="+8801782213173">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        WhatsApp
      </a>
      <a href="https://github.com/SafinRweb" target="_blank" class="c-link font-mono text-[10.5px] tracking-[0.2em] text-white/[0.45] uppercase inline-flex items-center gap-3 transition-colors duration-300 relative pb-[2px] hover:text-white no-underline" data-scramble="github.com/SafinRweb">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
          <path d="M5.5 1a4.5 4.5 0 00-1.42 8.77c.22.04.3-.1.3-.21v-.76c-1.24.27-1.5-.6-1.5-.6a1.18 1.18 0 00-.5-.65c-.4-.28.03-.27.03-.27a.94.94 0 01.68.46 .95.95 0 001.3.37.94.94 0 01.28-.59c-1-.11-2.04-.5-2.04-2.21a1.73 1.73 0 01.46-1.2 1.6 1.6 0 01.04-1.18s.37-.12 1.23.46a4.24 4.24 0 012.24 0c.86-.58 1.23-.46 1.23-.46a1.6 1.6 0 01.05 1.18 1.73 1.73 0 01.45 1.2c0 1.72-1.05 2.1-2.05 2.2a1.06 1.06 0 01.3.83v1.22c0 .12.08.26.3.22A4.5 4.5 0 005.5 1z" stroke="currentColor" stroke-width=".6" fill="none" />
        </svg>
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/safinrlnk/" target="_blank" class="c-link font-mono text-[10.5px] tracking-[0.2em] text-white/[0.45] uppercase inline-flex items-center gap-3 transition-colors duration-300 relative pb-[2px] hover:text-white no-underline" data-scramble="linkedin.com/safinrlnk">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
          <rect x=".5" y=".5" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width=".8" />
          <path d="M2.5 4.5v4M2.5 2.5v.5M4.5 8.5V6a1.5 1.5 0 013 0v2.5M4.5 4.5v4" stroke="currentColor" stroke-width=".8" stroke-linecap="round" />
        </svg>
        LinkedIn
      </a>
    </div>

    <!-- Email CTA -->
    <a href="mailto:safinr.gg@gmail.com" class="c-email font-display text-[clamp(18px,2.5vw,38px)] text-white/[0.6] transition-colors duration-300 hover:text-white reveal rd2 no-underline" data-scramble="safinr.gg@gmail.com &rarr;">
      safinr.gg@gmail.com &rarr;
    </a>
  </div>

  <!-- Footer -->
  <footer class="mt-20 pt-[22px] border-t border-white/[0.07] flex justify-between items-center flex-wrap gap-3.5">
    <span class="foot-t font-mono text-[10px] tracking-[0.18em] text-white/[0.18] uppercase">&copy; 2025 Safin Rahman</span>
    <span class="foot-t font-mono text-[10px] tracking-[0.18em] text-white/[0.18] uppercase">Designed &amp; Developed by Safin</span>
    <span class="foot-t font-mono text-[10px] tracking-[0.18em] text-white/[0.18] uppercase">Dhaka, Bangladesh</span>
  </footer>
</section>

<style>
  .c-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.55);
    transition: width 0.38s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .c-link:hover::after {
    width: 100%;
  }

  .reveal {
    opacity: 0;
    transform: translateY(34px);
    transition: opacity 0.85s ease, transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  .rd2 { transition-delay: 0.2s; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ScrollTrigger reveals for contact section
  document.querySelectorAll<HTMLElement>('#contact .reveal').forEach((el) => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 90%',
      once: true,
      onEnter: () => el.classList.add('in'),
    });
  });
</script>
