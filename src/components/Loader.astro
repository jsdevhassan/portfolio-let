---
// Loader component - animated loading screen with GSAP
---

<div
    id="loader"
    style="position:fixed;inset:0;background:#060606;z-index:9100;overflow:hidden;pointer-events:all;"
>
    <div
        id="ld-ticks"
        aria-hidden="true"
        style="position:absolute;left:clamp(22px,5vw,80px);top:0;bottom:0;display:flex;flex-direction:column;justify-content:space-between;padding:2em 0;pointer-events:none;"
    >
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
        <div class="ld-t"></div>
    </div>
    <div
        id="ld-name"
        aria-hidden="true"
        style="position:absolute;top:0;left:0;font-family:'MetrikTrial','Impact',sans-serif;font-size:clamp(72px,16.67vw,260px);line-height:.82;letter-spacing:-.01em;padding:.06em .07em;user-select:none;white-space:nowrap;"
    >
        <span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >H</span
        ><span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >A</span
        ><span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >S</span
        ><span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >S</span
        ><span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >A</span
        ><span
            style="display:inline-block;color:rgba(255,255,255,.08);will-change:color;"
            >N</span
        >
    </div>
    <div
        id="ld-status"
        style="position:absolute;bottom:clamp(80px,12vw,160px);left:clamp(22px,5vw,80px);font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.28em;color:rgba(255,255,255,.22);text-transform:uppercase;"
    >
        Initialising
    </div>
    <div
        id="ld-num"
        style="position:absolute;bottom:0;right:0;font-family:'Instrument Serif',serif;font-size:clamp(72px,16.67vw,260px);line-height:.82;letter-spacing:-.01em;color:rgba(255,255,255,.92);padding:.06em .07em;text-align:right;user-select:none;"
    >
        0
    </div>
    <div
        id="ld-prog"
        style="position:absolute;bottom:0;left:0;height:1px;width:0%;background:rgba(255,255,255,.2);transition:width .08s linear;"
    >
    </div>
</div>

<style>
    .ld-t {
        width: 14px;
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
    }
</style>

<script>
    import { gsap } from "gsap";

    function initLoader() {
        const ldr = document.getElementById("loader");
        const numEl = document.getElementById("ld-num");
        const progEl = document.getElementById("ld-prog");
        const statEl = document.getElementById("ld-status");
        const spans = document.querySelectorAll("#ld-name span");
        const site = document.getElementById("site");

        if (!ldr || !numEl || !progEl || !statEl || !site) return;

        const STATS = [
            "Initialising",
            "Loading assets",
            "Compiling",
            "Mounting",
            "Ready",
        ];
        const counter = { val: 0 };

        gsap.to(counter, {
            val: 100,
            duration: 2.5,
            ease: "power3.inOut",
            onUpdate: () => {
                const v = Math.floor(counter.val);
                numEl.textContent = String(v);
                progEl.style.width = v + "%";
                statEl.textContent =
                    STATS[Math.floor((v / 100) * (STATS.length - 1))];

                spans.forEach((s, i) => {
                    const threshold = (i / spans.length) * 100;
                    if (v >= threshold) {
                        const lp = Math.min(
                            (v - threshold) / (100 / spans.length),
                            1,
                        );
                        (s as HTMLElement).style.color =
                            `rgba(255,255,255,${(0.08 + lp * 0.92).toFixed(3)})`;
                    }
                });
            },
            onComplete: () => {
                numEl.textContent = "100";
                statEl.textContent = "Ready";
                spans.forEach(
                    (s) =>
                        ((s as HTMLElement).style.color =
                            "rgba(255,255,255,1)"),
                );
                progEl.style.width = "100%";

                gsap.to(ldr, {
                    y: "-100%",
                    duration: 0.9,
                    ease: "power4.inOut",
                    delay: 0.38,
                    onStart: () => {
                        site!.classList.add("in");
                    },
                    onComplete: () => {
                        ldr.style.display = "none";
                    },
                });
            },
        });
    }

    // Ensure DOM is ready before running
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLoader);
    } else {
        initLoader();
    }
</script>
