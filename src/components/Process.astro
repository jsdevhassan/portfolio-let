---
// Process section — "How I Work"
const steps = [
  { num: '01', title: 'Discover & Define', tag: 'Research • Planning' },
  { num: '02', title: 'Architect & Design', tag: 'Systems • Structure' },
  { num: '03', title: 'Build & Engineer', tag: 'Code • Craft' },
  { num: '04', title: 'Ship & Iterate', tag: 'Deploy • Refine' },
];
---

<section id="process" class="section px-[clamp(20px,4vw,64px)] py-[clamp(80px,12vh,140px)] border-t border-white/[0.07]">
  <p class="s-label font-mono text-[11px] tracking-[0.32em] text-white/[0.26] uppercase flex items-center gap-3 mb-14">
    <span class="block w-7 h-px bg-white/[0.18]"></span>
    <span class="text-white/[0.18] mr-1.5">02</span> How I Work
  </p>

  <div class="process-list flex flex-col">
    {steps.map((step, idx) => (
      <div
        class:list={[
          'proc-item grid items-center py-[clamp(24px,4vw,44px)] border-b border-white/[0.06] overflow-hidden relative reveal',
          idx === 0 ? 'border-t border-white/[0.06]' : '',
          idx > 0 ? `rd${idx}` : '',
        ]}
        style="transition: padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1);"
      >
        <span class="proc-n font-display text-[clamp(28px,3vw,48px)] text-white/[0.12] tracking-[-0.01em]">{step.num}</span>
        <span class="proc-title font-display text-[clamp(24px,3vw,46px)] tracking-[-0.01em] text-white/[0.8] transition-colors duration-300" data-scramble={step.title}>{step.title}</span>
        <span class="proc-tag font-mono text-[10px] tracking-[0.2em] text-white/[0.22] uppercase text-right">{step.tag}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .proc-item {
    grid-template-columns: 80px 1fr auto;
    gap: clamp(20px, 4vw, 60px);
  }

  .proc-item::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    top: auto;
    height: 0;
    background: rgba(255, 255, 255, 0.03);
    transition: height 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .proc-item:hover::before {
    height: 100%;
  }

  .proc-item:hover {
    padding-left: 20px;
  }

  .proc-item:hover .proc-title {
    color: #fff;
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(34px);
    transition: opacity 0.85s ease, transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  .rd1 { transition-delay: 0.1s; }
  .rd2 { transition-delay: 0.2s; }
  .rd3 { transition-delay: 0.3s; }

  @media (max-width: 900px) {
    .proc-item {
      grid-template-columns: 50px 1fr;
    }
    .proc-tag {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ScrollTrigger reveals
  document.querySelectorAll<HTMLElement>('#process .reveal').forEach((el) => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 90%',
      once: true,
      onEnter: () => el.classList.add('in'),
    });
  });

  // Magnetic pull effect using GSAP
  document.querySelectorAll<HTMLElement>('.proc-item').forEach((item) => {
    const xTo = gsap.quickTo(item, 'x', { duration: 0.15, ease: 'power2.out' });
    const yTo = gsap.quickTo(item, 'y', { duration: 0.15, ease: 'power2.out' });

    item.addEventListener('mousemove', (e) => {
      const r = item.getBoundingClientRect();
      const dx = (e.clientX - r.left - r.width / 2) * 0.04;
      const dy = (e.clientY - r.top - r.height / 2) * 0.08;
      xTo(dx);
      yTo(dy);
    });

    item.addEventListener('mouseleave', () => {
      gsap.to(item, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
    });

    // Scramble on hover
    item.addEventListener('mouseenter', () => {
      const titleEl = item.querySelector<HTMLElement>('.proc-title');
      if (!titleEl) return;
      const orig = titleEl.getAttribute('data-scramble') || titleEl.textContent || '';
      const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*<>/\\|~';
      if ((titleEl as any)._scrambleTimer) clearInterval((titleEl as any)._scrambleTimer);
      const totalFrames = Math.ceil(600 / 48);
      let it = 0;
      (titleEl as any)._scrambleTimer = setInterval(() => {
        titleEl.textContent = orig
          .split('')
          .map((c, i) => {
            if (c === ' ') return ' ';
            if (i < Math.floor(it / (totalFrames / orig.length))) return c;
            return GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
          })
          .join('');
        if (++it >= totalFrames) {
          titleEl.textContent = orig;
          clearInterval((titleEl as any)._scrambleTimer);
        }
      }, 48);
    });
  });
</script>
